{
  "name": "@grant-vine/wunderkind",
  "version": "0.4.0",
  "description": "Wunderkind — a generic oh-my-opencode addon package with specialist agents for any software product team",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "wunderkind": "bin/wunderkind.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "agents/",
    "skills/",
    ".claude-plugin/",
    "bin/",
    "wunderkind.config.jsonc",
    "oh-my-opencode.jsonc"
  ],
  "scripts": {
    "build": "tsc && bun run dist/build-agents.js",
    "dev": "tsc --watch",
    "prepublishOnly": "bun run build",
    "test": "bun test tests/unit/",
    "test:contract": "bun test tests/",
    "bench": "bun run tests/perf/adapter-benchmark.ts"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "@huggingface/transformers": "^3.8.1",
    "@opencode-ai/plugin": "^1.2.18",
    "@qdrant/js-client-rest": "^1.17.0",
    "commander": "^13.1.0",
    "fflate": "^0.8.2",
    "jsonc-parser": "^3.3.1",
    "mem0ai": "^2.2.4",
    "oh-my-opencode": "^3.10.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.3"
  },
  "keywords": [
    "oh-my-opencode",
    "opencode",
    "plugin",
    "wunderkind",
    "agents",
    "ai-agents"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/grant-vine/wunderkind"
  },
  "trustedDependencies": [
    "onnxruntime-node"
  ]
}
