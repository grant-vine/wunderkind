{
  "name": "@grant-vine/wunderkind",
  "version": "0.9.6",
  "description": "Wunderkind \u2014 specialist AI agent addon for OpenCode with 12 professional agents for any software product team",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "wunderkind": "bin/wunderkind.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "agents/",
    "commands/",
    "schemas/",
    "skills/",
    ".claude-plugin/",
    "bin/",
    "wunderkind.config.jsonc"
  ],
  "scripts": {
    "build": "tsc && bun run dist/build-agents.js",
    "dev": "tsc --watch",
    "prepublishOnly": "bun run build",
    "test": "bun test tests/unit/",
    "test:contract": "bun test tests/unit/"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "@opencode-ai/plugin": "^1.2.18",
    "commander": "^13.1.0",
    "jsonc-parser": "^3.3.1",
    "oh-my-opencode": "^3.11.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.3"
  },
  "keywords": [
    "oh-my-openagent",
    "oh-my-opencode",
    "opencode",
    "plugin",
    "wunderkind",
    "agents",
    "ai-agents"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/grant-vine/wunderkind"
  }
}
