{
  "name": "@grant-vine/wunderkind",
  "version": "0.19.1",
  "description": "Wunderkind \u2014 specialist AI agent addon for OpenCode with 6 retained specialist agents for any software product team",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "wunderkind": "bin/wunderkind.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "agents/",
    "commands/",
    "schemas/",
    "skills/",
    ".claude-plugin/",
    "bin/",
    "oh-my-openagent.jsonc",
    "oh-my-opencode.jsonc",
    "wunderkind.config.jsonc"
  ],
  "scripts": {
    "build": "tsc && bun run dist/build-agents.js",
    "dev": "tsc --watch",
    "prepublishOnly": "bun run build",
    "test": "bun test tests/unit/",
    "test:contract": "bun test tests/unit/",
    "test:coverage": "bun test --coverage tests/unit/",
    "test:coverage:config-manager": "bun test --coverage tests/unit/config-manager-coverage.test.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "@opencode-ai/plugin": "1.17.8",
    "@opencode-ai/sdk": "1.17.8",
    "commander": "^13.1.0",
    "jsonc-parser": "^3.3.1",
    "oh-my-openagent": "4.11.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "oh-my-openagent",
    "oh-my-opencode",
    "opencode",
    "plugin",
    "wunderkind",
    "agents",
    "ai-agents"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/grant-vine/wunderkind"
  },
  "overrides": {
    "picomatch": "4.0.4",
    "@hono/node-server": "1.19.13",
    "hono": "4.12.18",
    "path-to-regexp": "8.4.2",
    "fast-uri": "3.1.2",
    "ip-address": "10.2.0",
    "uuid": "13.0.2"
  }
}
